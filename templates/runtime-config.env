# code-dispatcher runtime config
# CODE_DISPATCHER_* keys control dispatcher behavior.
# Other keys are injected into backend processes and override same-name inherited values.

# CODE_DISPATCHER_TIMEOUT in seconds (default: 7200)
CODE_DISPATCHER_TIMEOUT=7200

# Accepted true values: 1, true, yes, on. Accepted false values: 0, false, no, off.
CODE_DISPATCHER_ASCII_MODE=false
CODE_DISPATCHER_MAX_PARALLEL_WORKERS=0
# <= 0 waits indefinitely.
CODE_DISPATCHER_LOGGER_CLOSE_TIMEOUT_MS=5000

# Backend model override (optional, leave empty to use CLI defaults)
# CODE_DISPATCHER_GEMINI_MODEL=
# CODE_DISPATCHER_CODEX_MODEL=
